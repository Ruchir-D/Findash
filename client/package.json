    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.0.5",
    "react-router-dom": "^6.10.0",
    "recharts": "^2.5.0",
    "regression": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.15.11",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/regression": "^2.0.2",
    "@vitejs/plugin-react": "^3.1.0",
    "eslint": "^8.38.0",
